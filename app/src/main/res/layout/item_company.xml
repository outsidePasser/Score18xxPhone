<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    android:orientation="horizontal"
    android:textSize="16sp">

    <TextView
        android:id="@+id/item_company_name"
        style="@style/CompanyName" />

    <TextView
        android:id="@+id/item_company_or1"
        style="@style/CompanyInput" />

    <EditText
        android:id="@+id/item_company_or2"
        style="@style/CompanyInput"
        android:inputType="number"
        android:imeOptions="actionDone"/>

    <TextView
        android:id="@+id/item_company_or3"
        style="@style/CompanyInput" />

    <TextView
        android:id="@+id/item_company_stock_price"
        style="@style/CompanyInput" />

</LinearLayout>
