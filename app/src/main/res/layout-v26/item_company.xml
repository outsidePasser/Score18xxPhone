<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    android:orientation="horizontal"
    android:baselineAligned="false"
    android:textSize="16sp"
    >

    <TextView
        android:id="@+id/item_company_name"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_weight="1"
        android:gravity="center"
        android:background="@drawable/rounded_corner"
        android:textColor="@color/white"
        android:layout_marginLeft="5sp"
        android:layout_marginRight="5sp"
        android:paddingLeft="10sp"
        android:paddingRight="10sp"
        android:maxLines="1"
        android:textSize="18sp"
        android:ellipsize="end"
        />

    <TextView
        android:id="@+id/item_company_or1"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_weight="1"
        android:gravity="center"
        android:background="@drawable/rounded_corner_dark_gray"
        android:textColor="@color/white"
        android:layout_marginLeft="5sp"
        android:layout_marginRight="5sp"
        android:textSize="24sp"
        />

    <TextView
        android:id="@+id/item_company_or2"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_weight="1"
        android:gravity="center"
        android:background="@drawable/rounded_corner_dark_gray"
        android:textColor="@color/white"
        android:layout_marginLeft="5sp"
        android:layout_marginRight="5sp"
        android:textSize="24sp"
        />

    <TextView
        android:id="@+id/item_company_or3"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_weight="1"
        android:gravity="center"
        android:background="@drawable/rounded_corner_dark_gray"
        android:textColor="@color/white"
        android:layout_marginLeft="5sp"
        android:layout_marginRight="5sp"
        android:textSize="24sp"
        />

    <TextView
        android:id="@+id/item_company_or4"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_weight="1"
        android:gravity="center"
        android:background="@drawable/rounded_corner_dark_gray"
        android:textColor="@color/white"
        android:layout_marginLeft="5sp"
        android:layout_marginRight="5sp"
        android:textSize="24sp"
        />

    <TextView
        android:id="@+id/item_company_stock_price"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_weight="1"
        android:gravity="center"
        android:background="@drawable/rounded_corner_dark_gray"
        android:textColor="@color/white"
        android:layout_marginLeft="5sp"
        android:layout_marginRight="5sp"
        android:textSize="24sp"
        />

</LinearLayout>